# Copy to keystore.properties (NOT committed) and fill in to sign release builds.
# Generate a keystore once with:
#   keytool -genkeypair -v -keystore kultura-release.jks -keyalg RSA -keysize 2048 \
#           -validity 10000 -alias kultura
# Keep the .jks file and these credentials safe — losing them means you can
# never update the app on Play Store again.
storeFile=../kultura-release.jks
storePassword=
keyAlias=kultura
keyPassword=
