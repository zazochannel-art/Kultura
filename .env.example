# Copy this file to .env and fill in real values. Do NOT commit .env.
# Rotate every key that has ever been committed before reusing this repo.

# OpenAI key used by the /api/ai-import server endpoint.
OPENAI_API_KEY=

# Supabase service role key — full admin access to your Supabase project.
# Only used server-side (never expose to the browser).
SUPABASE_SERVICE_ROLE_KEY=
